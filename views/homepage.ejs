<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GameVault | Home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('./partials/navbar') %>

    <main class="page-shell">
        <% if (featuredGame) { %>
            <section class="hero-panel">
                <div class="hero-content">
                    <p class="eyebrow"><i class="fa-solid fa-fire"></i> Next-gen game discovery</p>
                    <h1><%= featuredGame.title %></h1>
                    <p><%= featuredGame.description %></p>
                    <div class="hero-actions">
                        <a class="btn btn-primary" href="/games">Explore Games</a>
                        <a class="btn btn-secondary" href="/library">View Library</a>
                    </div>
                    <div class="hero-stats">
                        <div>
                            <strong><%= totalGames %>+</strong>
                            <span>Curated titles</span>
                        </div>
                        <div>
                            <strong><%= totalGenres %></strong>
                            <span>Genres in catalog</span>
                        </div>
                        <div>
                            <strong><%= totalPlatforms %></strong>
                            <span>Platforms tracked</span>
                        </div>
                    </div>
                </div>
                <div class="hero-card">
                    <% if (featuredGame.coverImage) { %>
                        <img src="<%= featuredGame.coverImage %>" alt="<%= featuredGame.title %> cover">
                    <% } else { %>
                        <div class="hero-card-media">
                            <span><%= featuredGame.title %></span>
                        </div>
                    <% } %>
                    <div class="hero-card-content">
                        <p class="eyebrow">Featured release</p>
                        <h3><%= featuredGame.title %></h3>
                        <p><%= featuredGame.description %></p>
                        <div class="chip-row">
                            <% (Array.isArray(featuredGame.genre) ? featuredGame.genre : []).forEach(oneGenre => { %>
                                <span class="badge"><%= oneGenre.name %></span>
                            <% }) %>
                            <% (Array.isArray(featuredGame.platform) ? featuredGame.platform : []).forEach(onePlatform => { %>
                                <span class="badge"><%= onePlatform.name %></span>
                            <% }) %>
                            <% if (featuredGame.releaseDate) { %>
                                <span class="badge"><%= featuredGame.releaseDate %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </section>
        <% } %>

        <section class="section-block">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Featured picks</p>
                    <h2>Recently added games</h2>
                </div>
                <a class="text-link" href="/games">View catalog <i class="fa-solid fa-arrow-right"></i></a>
            </div>

            <% if (games.length > 0) { %>
                <div class="card-grid">
                    <% games.forEach(game => { %>
                        <article class="game-card" onclick="window.location.href='/games/<%= game._id %>'">
                            <% if (game.coverImage) { %>
                                <img src="<%= game.coverImage %>" alt="<%= game.title %> cover">
                            <% } else { %>
                                <div class="game-card-fallback">
                                    <span><%= game.title %></span>
                                </div> 
                            <% } %>
                            <div class="game-card-content">
                                <div class="game-meta">
                                    <% if (game.company && game.company.name) { %>
                                        <span class="badge"><%= game.company.name %></span>
                                    <% } %>
                                    <% if (game.releaseDate) { %>
                                        <span class="badge"><%= game.releaseDate %></span>
                                    <% } %>
                                </div>
                                <h3><%= game.title %></h3>
                                <p><%= game.description %></p>
                                <div class="chip-row">
                                    <% (Array.isArray(game.genre) ? game.genre : []).forEach(oneGenre => { %>
                                        <span class="chip"><%= oneGenre.name %></span>
                                    <% }) %>
                                    <% (Array.isArray(game.platform) ? game.platform : []).forEach(onePlatform => { %>
                                        <span class="chip"><%= onePlatform.name %></span>
                                    <% }) %>
                                </div>
                                <div class="card-actions">
                                    <a class="btn btn-primary btn-small" href="/games/<%= game._id %>">View details</a>
                                    <a class="btn btn-secondary btn-small" href="/games">Browse catalog</a>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="content-card empty-state">
                    <h3>No games available yet.</h3>
                    <p>New releases will appear here as they are added to the library.</p>
                </div>
            <% } %>
        </section>
    </main>
</body>
</html>