<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platforms</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="page-shell">
        <section class="section-block">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Devices</p>
                    <h2>Platforms</h2>
                </div>
            </div>
            <div class="card-grid">
                <% platform.forEach(onePlatform => { %>
                    <article class="game-card" onclick="location.href='/<%= onePlatform._id %>'">
                        <img src="<%= onePlatform.logo %>" alt="<%= onePlatform.name %>">
                        <div class="game-card-content">
                            <h3><%= onePlatform.name %></h3>
                            <a class="btn btn-primary btn-small" href="/<%= onePlatform._id %>">View games</a>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    </main>
</body>
</html>