<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Platform</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../../partials/navbar') %>

    <main class="page-shell auth-shell">
        <section class="form-panel">
            <div class="form-heading">
                <p class="eyebrow"><i class="fa-solid fa-plus"></i> New platform</p>
                <h1>Create a platform entry.</h1>
            </div>
            <form class="stacked-form" action="/admin/platforms" method="POST">
                <label class="field" for="name">
                    <span>Name</span>
                    <input type="text" id="name" name="name" required>
                </label>
                <label class="field" for="manufacturer">
                    <span>Manufacturer</span>
                    <select id="manufacturer" name="manufacturer">
                        <option value="">Select Manufacturer</option>
                        <% manufacturers.forEach(manufacturer => { %>
                            <option value="<%= manufacturer._id %>"><%= manufacturer.name %></option>
                        <% }) %>
                    </select>
                </label>
                <label class="field" for="logo">
                    <span>Logo URL</span>
                    <input type="text" id="logo" name="logo">
                </label>

                <button class="btn btn-primary" type="submit">Create Platform</button>
            </form>
        </section>
    </main>
</body>
</html>