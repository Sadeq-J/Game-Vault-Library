<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= company.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../../partials/navbar') %>

    <main class="page-shell">
        <section class="content-card detail-card">
            <div class="company-hero">
                <img src="<%= company.logo %>" alt="<%= company.name %> logo">
                <div>
                    <p class="eyebrow"><i class="fa-solid fa-building"></i> Studio profile</p>
                    <h1><%= company.name %></h1>
                    <p><%= company.description %></p>
                    <p><strong>Country:</strong> <%= company.country %></p>
                    <div class="stacked-actions" style="margin-top: 1rem;">
                        <form action="/admin/companies/<%= company._id %>/edit" method="GET">
                            <button class="btn btn-secondary" type="submit">Edit</button>
                        </form>
                        <form action="/admin/companies/<%= company._id %>?_method=DELETE" method="POST">
                            <button class="btn btn-danger" type="submit">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>