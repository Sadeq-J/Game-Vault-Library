<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= game.title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../../partials/navbar') %>

    <main class="page-shell">
        <section class="content-card detail-card">
            <div class="company-hero">
                <img src="<%= game.coverImage %>" alt="<%= game.title %> cover">
                <div>
                    <p class="eyebrow"><i class="fa-solid fa-gamepad"></i> Game management</p>
                    <h1><%= game.title %></h1>
                    <p><%= game.description %></p>
                    <p><strong>Release Date:</strong> <%= game.releaseDate %></p>
                    <p><strong>Company:</strong> <%= game.company.name %></p>
                    <div class="chip-row" style="margin-top: 0.8rem;">
                        <% game.genre.forEach(oneGenre => { %>
                            <span class="chip"><%= oneGenre.name %></span>
                        <% }) %>
                    </div>
                    <div class="chip-row" style="margin-top: 0.6rem;">
                        <% game.platform.forEach(onePlatform => { %>
                            <span class="chip"><%= onePlatform.name %></span>
                        <% }) %>
                    </div>
                    <div class="stacked-actions" style="margin-top: 1rem;">
                        <a class="btn btn-secondary" href="/admin/games/<%= game._id %>/edit">Edit Game</a>
                        <form action="/admin/games/<%= game._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this game?');">
                            <button class="btn btn-danger" type="submit">Delete Game</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>